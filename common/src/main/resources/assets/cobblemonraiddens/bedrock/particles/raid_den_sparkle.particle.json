{
    "format_version": "1.10.0",
    "particle_effect": {
        "description": {
            "identifier": "cobblemonraiddens:raid_den_sparkle",
            "basic_render_parameters": {
                "material": "particles_alpha",
                "texture": "cobblemonraiddens:textures/particles/sparkle"
            }
        },
        "components": {
            "minecraft:emitter_rate_steady": {
                "spawn_rate": 100,
                "max_particles": 300
            },
            "minecraft:emitter_lifetime_once": {
                "active_time": 1
            },
            "minecraft:emitter_shape_point": {
                "offset": [
                    "0.65 * math.sin(v.particle_random_1 * 360) * v.particle_random_2 * (1 - 0.4 * v.particle_random_4)",
                    "1.1 * v.particle_random_4",
                    "0.65 * math.cos(v.particle_random_1 * 360) * v.particle_random_2 * (1 - 0.4 * v.particle_random_4)"
                ],
                "direction": [
                    "-0.6 * math.sin(v.particle_random_1 * 360) * v.particle_random_2",
                    "0.7 + 0.3 * math.random(0, 1)",
                    "0.6 * math.cos(v.particle_random_1 * 360) * v.particle_random_2"
                ]
            },
            "minecraft:particle_lifetime_expression": {
                "max_lifetime": 1
            },
            "minecraft:particle_initial_spin": {
                "rotation": "math.random(-180, 180)"
            },
            "minecraft:particle_initial_speed": 0.05,
            "minecraft:particle_motion_dynamic": {},
            "minecraft:particle_appearance_billboard": {
                "size": [
                    "0.025 + 0.02 * (v.particle_random_2 + v.particle_random_4)",
                    "0.025 + 0.02 * (v.particle_random_2 + v.particle_random_4)"
                ],
                "facing_camera_mode": "rotate_xyz",
                "uv": {
                    "texture_width": 8,
                    "texture_height": 48,
                    "flipbook": {
                        "base_UV": [0, 0],
                        "size_UV": [8, 8],
                        "step_UV": [0, 8],
                        "max_frame": "4 + 2 * math.floor(v.particle_random_3 * 2)",
                        "stretch_to_lifetime": true,
                        "loop": true
                    }
                }
            },
            "minecraft:particle_appearance_tinting": {
                "color": {
                    "interpolant": "v.particle_age / v.particle_lifetime",
                    "gradient": {
                        "0.0": "#80FFC8C8",
                        "0.14": "#80FFE2C4",
                        "0.28": "#80FFFDBE",
                        "0.43": "#80C1FFBF",
                        "0.57": "#80C1CDFF",
                        "0.71": "#80E4BBFF",
                        "0.86": "#80FFB8F7",
                        "1.0": "#80FFC8C8"
                    }
                }
            }
        }
    }
}